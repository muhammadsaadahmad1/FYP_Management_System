{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Start Live Server",
            "type": "shell",
            "command": "npx",
            "args": [
                "live-server",
                "--port=5500",
                "--host=localhost",
                "--open=/index.html",
                "--quiet"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Stop Live Server",
            "type": "shell",
            "command": "taskkill",
            "args": [
                "/F",
                "/IM",
                "node.exe"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
